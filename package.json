{
  "name": "short-video-script-generator",
  "version": "1.0.0",
  "description": "短视频剧本生成器 - 基于火山引擎大模型",
  "main": "src/electron/main.js",
  "scripts": {
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:build": "electron-builder",
    "electron:build:win": "electron-builder --win",
    "electron:build:mac": "electron-builder --mac",
    "electron:build:linux": "electron-builder --linux",
    "start": "python src/backend/api.py",
    "dev": "npm run electron:dev"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.drama.scriptgenerator",
    "productName": "短视频剧本生成器",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src/backend/dist/api.exe",
        "to": "api.exe",
        "filter": ["**/api.exe"]
      },
      {
        "from": "src/backend/dist/api",
        "to": "api",
        "filter": ["**/api"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
